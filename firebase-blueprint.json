{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "InterviewPrep": {
      "title": "Interview Preparation",
      "description": "Stores generated interview prep data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "resumeText": { "type": "string" },
        "targetRole": { "type": "string" },
        "analysis": {
          "type": "object",
          "properties": {
            "behavioral": { "type": "array", "items": { "$ref": "QuestionSet" } },
            "technical": { "type": "array", "items": { "$ref": "QuestionSet" } },
            "weakSpots": { "type": "array", "items": { "type": "object" } },
            "confidenceTips": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "resumeText", "analysis", "createdAt"]
    },
    "QuestionSet": {
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "intent": { "type": "string" },
        "answers": {
          "type": "object",
          "properties": {
            "strong": { "type": "string" },
            "natural": { "type": "string" },
            "short": { "type": "string" }
          }
        },
        "followUps": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile."
    },
    "/preps/{prepId}": {
      "schema": "InterviewPrep",
      "description": "Interview prep sessions."
    }
  }
}
